APP_ENV=development
APP_NAME=plant-factory

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

FIBER_BODY_LIMIT=4194304
FIBER_PREFORK=false
FIBER_TRUSTED_PROXIES=127.0.0.1,::1
FIBER_COMPRESS_LEVEL=1

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Request-ID
CORS_ALLOW_CREDENTIALS=false
CORS_EXPOSE_HEADERS=Content-Type,Authorization,X-Request-ID

LOG_LEVEL=debug

DB_HOST=postgres
DB_PORT=5432
DB_USER=plant-factory
DB_PASSWORD=plant-factory
DB_NAME=plant-factory
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MIN_IDLE_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=change-me-min-64-characters-long-secret
JWT_ISSUER=plant-factory

FRONTEND_ALLOWED_URL=https://local.plant-factory.com,https://api-local.plant-factory.com

AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_URL=http://api-local.plant-factory.com/auth/google/callback
AUTH_SOCIAL_STATE_DURATION=10m
AUTH_ACCESS_TOKEN_DURATION=15m
AUTH_REFRESH_TOKEN_DURATION=168h
AUTH_TOLERANCE_DURATION=3m
AUTH_CACHE_USER_DURATION=5m

SWAGGER_USERNAME=
SWAGGER_PASSWORD=
